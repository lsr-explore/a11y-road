{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "includes": [
      "apps/**",
      "libs/**",
      "docs/**",
      ".storybook/**",
      "*.json",
      "*.ts",
      "*.js",
      "*.md",
      "!**/node_modules",
      "!**/.next",
      "!**/dist",
      "!**/out-tsc",
      "!**/coverage",
      "!**/test-output",
      "!**/.nx",
      "!**/next-env.d.ts",
      "!**/public/pagefind",
      "!.vercel",
      "!storybook-static",
      "!manifest.json",
      "!**/test-results"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "recommended": false
      },
      "suspicious": {
        "noExplicitAny": "warn"
      },
      "performance": {
        "noImgElement": "warn"
      }
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  }
}
