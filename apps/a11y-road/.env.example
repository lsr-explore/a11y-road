# Set to "false" to hide the a11y demo tools (toggle, side panel, summary nav link).
# Any other value or omitting this variable will show them.
NEXT_PUBLIC_SHOW_A11Y_TOOLS=true
SITE_AUTH_PASSWORD=changeme
SITE_AUTH_ENABLED=true
SITE_AUTH_USERNAME=changeme
COOKIE_SECRET=generate-a-random-string-here
NEXT_PUBLIC_ISSUE_LOG_PAGE=true

# Set to "true" to enable the manifest export bridge (exposes window.__a11yManifest).
# Used by the Playwright export script to extract page/element/break data.
NEXT_PUBLIC_ENABLE_MANIFEST_EXPORT=false
