{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "default",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(find src *)",
      "Bash(cat package.json)",
      "Bash(pnpm run *)",
      "Bash(pnpm exec *)",
      "Read(./**)"
    ],
    "ask": [
      "Bash(pnpm install *)",
      "Bash(npm install *)",
      "Bash(npx supabase *)",
      "Bash(supabase *)",
      "Bash(docker build *)",
      "Bash(docker compose *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Edit(./supabase/migrations/**)",
      "Edit(./package.json)",
      "Edit(./Dockerfile)",
      "Edit(./docker-compose*.yml)",
      "WebFetch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./.npmrc)",
      "Read(./.yarnrc)",
      "Read(./.pypirc)",
      "Read(./supabase/.branches/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/**)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf /**)",
      "Bash(rm -rf ~)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": ["git"],
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config",
        "./.env",
        "./.env.*"
      ],
      "denyWrite": [
        "/etc",
        "//etc",
        "/usr",
        "//usr",
        "/bin",
        "//bin",
        "/sbin",
        "//sbin",
        "/opt",
        "//opt"
      ]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "github.com",
        "raw.githubusercontent.com"
      ],
      "allowLocalBinding": true
    }
  },
  "respectGitignore": true,
  "cleanupPeriodDays": 20,
  "attribution": {
    "commit": "",
    "pr": ""
  }
}