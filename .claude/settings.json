{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "defaultMode": "default",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(find src *)",
      "Bash(cat package.json)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint *)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test)",
      "Bash(pnpm test *)",
      "Bash(pnpm exec vitest *)",
      "Bash(pnpm exec playwright test *)",
      "Read(./src/**)",
      "Read(./app/**)",
      "Read(./components/**)",
      "Read(./lib/**)",
      "Read(./utils/**)",
      "Read(./tests/**)",
      "Read(./playwright/**)",
      "Read(./vitest.config.*)",
      "Read(./eslint.config.*)",
      "Read(./biome.json)",
      "Read(./tailwind.config.*)",
      "Read(./postcss.config.*)",
      "Read(./tsconfig*.json)",
      "Read(./package.json)",
      "Read(./Dockerfile)",
      "Read(./docker-compose*.yml)",
      "Read(./README.md)",
      "Read(./CLAUDE.md)",
      "Read(./.claude/**)"
    ],
    "ask": [
      "Bash(pnpm install *)",
      "Bash(npm install *)",
      "Bash(npx supabase *)",
      "Bash(supabase *)",
      "Bash(docker build *)",
      "Bash(docker compose *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Edit(./supabase/migrations/**)",
      "Edit(./package.json)",
      "Edit(./Dockerfile)",
      "Edit(./docker-compose*.yml)",
      "WebFetch"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./.npmrc)",
      "Read(./.yarnrc)",
      "Read(./.pypirc)",
      "Read(./supabase/.branches/**)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/**)",
      "Bash(sudo *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(rm -rf /)",
      "Bash(npm publish *)",
      "Bash(pnpm publish *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "excludedCommands": ["git"],
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config",
        "/.env",
        "/.env.*"
      ],
      "denyWrite": [
        "//etc",
        "//usr",
        "//bin",
        "//sbin",
        "//opt"
      ]
    },
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "github.com",
        "raw.githubusercontent.com"
      ],
      "allowLocalBinding": true
    }
  },
  "respectGitignore": true,
  "cleanupPeriodDays": 20,
  "attribution": {
    "commit": "",
    "pr": ""
  }
}