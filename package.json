{
  "name": "@a11y-road/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "nx dev @a11y-road/a11y-road",
    "build": "nx build @a11y-road/a11y-road",
    "lint": "nx run-many -t lint --no-tui",
    "nx:reset": "nx reset",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "test:all": "vitest run --config apps/a11y-road/vitest.config.ts && vitest run --config libs/a11y-kit/vitest.config.ts",
    "test:all:coverage": "vitest run --coverage --config apps/a11y-road/vitest.config.ts && vitest run --coverage --config libs/a11y-kit/vitest.config.ts",
    "test": "vitest run --config apps/a11y-road/vitest.config.ts",
    "test:watch": "vitest --config apps/a11y-road/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config apps/a11y-road/vitest.config.ts",
    "e2e": "nx e2e apps/maple-valley-health-e2e --no-tui",
    "typecheck": "nx run-many -t typecheck --no-tui",
    "stylelint": "stylelint \"apps/**/*.css\" \"libs/**/*.css\"",
    "knip": "knip",
    "clean": "rm -rf dist out-tsc coverage test-output .next apps/*/.next apps/*/out-tsc apps/*/dist libs/*/dist .nx/cache",
    "clean:all": "pnpm clean && pnpm nx:reset && rm -rf node_modules ",
    "check:all": "pnpm format:check && pnpm lint && pnpm stylelint && pnpm typecheck && pnpm knip && pnpm test:all:coverage"
  },
  "private": true,
  "dependencies": {
    "next": "~16.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.6",
    "@eslint/js": "^9.8.0",
    "@next/eslint-plugin-next": "^16.0.1",
    "@nx/devkit": "22.5.4",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/next": "22.5.4",
    "@nx/playwright": "22.5.4",
    "@nx/vite": "^22.5.4",
    "@nx/workspace": "22.5.4",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "10.4.13",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "knip": "^5.86.0",
    "nx": "22.5.4",
    "postcss": "8.4.38",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "3.4.3",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "vitest-canvas-mock": "^1.1.3"
  }
}
