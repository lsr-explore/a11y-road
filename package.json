{
  "name": "@a11y-road/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "------------------- dev -------------------": "noop",
    "dev": "nx dev @a11y-road/a11y-road",
    "build": "nx build @a11y-road/a11y-road",
    "build:debug": "pnpm nx:reset && npx next build apps/a11y-road --webpack --debug",
    "analyze": "pnpm nx:reset && ANALYZE=true nx build @a11y-road/a11y-road -- --webpack",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:clean": "docker compose -f docker-compose.dev.yml down --rmi local --volumes --remove-orphans",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "postbuild": "pagefind --site apps/a11y-road/.next/server/app --output-path apps/a11y-road/public/pagefind",
    "search:index": "pagefind --site apps/a11y-road/.next/server/app --output-path apps/a11y-road/public/pagefind",
    "pandoc": "pandoc --defaults pandoc/pdf-templates/pdf-defaults.yaml",
    "vercel-deploy": "vercel --prod --confirm",
    "tree": "tree -l 3 --ignore 'node_modules, coverage, .next, playwright-report, test-results, storybook-static, .nx'",
    "------------------- code quality -------------------": "noop",
    "lint": "nx run-many -t lint --no-tui",
    "lint:fix": "eslint . --fix",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "typecheck": "nx run-many -t typecheck --no-tui",
    "stylelint": "stylelint \"apps/**/*.css\" \"libs/**/*.css\"",
    "stylelint:fix": "stylelint \"apps/**/*.css\" \"libs/**/*.css\" --fix",
    "markdownlint": "markdownlint-cli2 'apps/**/*.mdx' 'libs/**/*.mdx' 'docs/**/*.md'",
    "markdownlint:fix": "markdownlint-cli2 --fix 'apps/**/*.mdx' 'libs/**/*.mdx' 'docs/**/*.md'",
    "check:all": "pnpm format:check;  pnpm lint; pnpm stylelint; pnpm markdownlint; pnpm typecheck; pnpm knip; pnpm test:all:coverage ",
    "------------------- testing -------------------": "noop",
    "test:all": "vitest run --config apps/a11y-road/vitest.config.ts && vitest run --config libs/a11y-kit/vitest.config.ts",
    "test:all:coverage": "vitest run --coverage --config apps/a11y-road/vitest.config.ts && vitest run --coverage --config libs/a11y-kit/vitest.config.ts",
    "test": "vitest run --config apps/a11y-road/vitest.config.ts",
    "test:watch": "vitest --config apps/a11y-road/vitest.config.ts",
    "test:coverage": "vitest run --coverage --config apps/a11y-road/vitest.config.ts",
    "------------------- e2e -------------------": "noop",
    "e2e": "nx e2e apps/maple-valley-health-e2e --no-tui",
    "e2e:ui": "nx e2e apps/maple-valley-health-e2e test --ui",
    "e2e:report": "nx e2e apps/maple-valley-health-e2e show-report",
    "------------------- static analysis -------------------": "noop",
    "circular": "dependency-cruiser --config .dependency-cruiser.js --output-type err apps/a11y-road/src libs/",
    "depcruise": "dependency-cruiser --config .dependency-cruiser.js --output-type dot apps/a11y-road/src libs/ | dot -T svg > deps.svg",
    "size": "pnpm build && size-limit",
    "------------------- dependencies -------------------": "noop",
    "outdated": "pnpm outdated",
    "knip": "knip",
    "------------------- cleanup -------------------": "noop",
    "nx:reset": "nx reset",
    "clean": "rm -rf dist out-tsc  .next apps/*/.next apps/*/out-tsc apps/*/dist libs/*/dist .nx/cache apps/a11y-road/public/pagefind .source .vercel tmp .nx/workspace-data",
    "clean:tests": "rm -rf playwright-report blob-report test-results test-output coverage *.lcov",
    "clean:pandoc": "rm -rf apps/a11y-road/pandoc/output",
    "clean:all": "pnpm clean && pnpm nx:reset && rm -rf node_modules && pnpm clean:pandoc && pnpm clean:tests",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "~16.2.1",
    "pino": "^10.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@next/eslint-plugin-next": "^16.2.1",
    "@next/mdx": "^16.2.1",
    "@nx/devkit": "22.6.1",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/next": "22.6.1",
    "@nx/playwright": "22.6.1",
    "@nx/react": "22.6.1",
    "@nx/vite": "^22.6.1",
    "@nx/vitest": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@playwright/test": "^1.36.0",
    "@size-limit/file": "^12.0.1",
    "@size-limit/webpack": "^12.0.1",
    "@size-limit/webpack-why": "^12.0.1",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.18",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "autoprefixer": "10.4.27",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-storybook": "^10.3.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^6.0.5",
    "markdownlint-cli2": "^0.22.0",
    "nx": "22.6.1",
    "pagefind": "^1.4.0",
    "pino-pretty": "^13.1.3",
    "postcss": "8.5.8",
    "size-limit": "^12.0.1",
    "storybook": "^10.3.3",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "3.4.3",
    "tslib": "^2.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "vitest-axe": "^0.1.0",
    "vitest-canvas-mock": "^1.1.4"
  }
}
